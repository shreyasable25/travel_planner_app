                            BoxShadow(
                              blurRadius: 12,
                              offset: Offset(0, 6),
                              color: Colors.black45,
                            ),
                          ],
                        ),
                        child: Center(
                          child: Icon(
                            Icons.arrow_forward,
                            size: 35,
                            color: Colors.white,
                          ),
                        ),
                      ),
                    ),
                    SizedBox(height: 20),
